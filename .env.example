# Copy this file to .env and fill in your values.
# Use python-dotenv or export manually: export VAR=value

# ── Django core ────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=hiddenbraj.settings
DJANGO_SECRET_KEY=replace-this-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ── Database (leave blank to use SQLite) ───────────────────────────────────
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# ── Custom admin panel token ───────────────────────────────────────────────
ADMIN_TOKEN=BrajDarshan@2026

# ── Email notifications (optional) ────────────────────────────────────────
GMAIL_USER=your.email@gmail.com
GMAIL_PASS=xxxx-xxxx-xxxx-xxxx     # 16-char Gmail App Password
ADMIN_EMAIL=alerts@yourdomain.com

# ── Google Sheets webhook (optional) ──────────────────────────────────────
# GOOGLE_SHEET_WEBHOOK=https://script.google.com/macros/s/YOUR_ID/exec

# ── Google Maps (optional — interactive map on homepage) ──────────────────
# Get your key: https://console.cloud.google.com/google/maps-apis/
# Enable: Maps JavaScript API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
